generator client {
  provider      = "prisma-client-js"
  output        = "../app/prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model City {
  id         Int    @id @map("_id")
  area       Float
  county_id  Int
  name       String
  population Int

  county County? @relation(fields: [county_id], references: [id])

  // 1:1 kapcsolat a County-vel, ahol a City a County székhelye
  // A kapcslatnak nevet kell adni, mert van másik kapcsolat is a két modell között
  // opcionális kapcsolat (?), mert nem minden város székhely
  seatOf County? @relation("oneToOne")

  @@map("cities")
}

model County {
  id           Int    @id @map("_id")
  area         Int
  country_part String
  name         String
  population   Int
  region       String
  seat_id      Int    @unique //1:1 kapcsolatnál az idegen kulcs egyedi kell legyen

  cities City[]

  // Az 1:1 kapcsolat definiálása
  // A kapcslatnak nevet kell adni, mert van másik kapcsolat is a két modell között
  // onDelete és onUpdate beállítások kellenek a körkörös hivatkozás elkerülése végett
  seat City @relation("oneToOne", fields: [seat_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("counties")
}
